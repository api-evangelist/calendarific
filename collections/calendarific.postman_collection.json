    {
      "id": "f512fcb7-979a-4b5a-a21f-602a4bd707f2",
      "name": "Holidays",
      "description": {
        "content": "Retrieve holiday data for any country and year.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "ac9087d8-d545-4c1b-8fff-285dd9bf637d",
          "name": "List Holidays",
          "request": {
            "name": "List Holidays",
            "description": {
              "content": "Returns holidays for a given country and year. Supports filtering\nby month, day, location (sub-region), holiday type, and language.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "holidays"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "api_key",
                  "value": "<string>",
                  "description": "(Required) Calendarific API key issued via the developer console."
                },
                {
                  "disabled": false,
                  "key": "country",
                  "value": "<string>",
                  "description": "(Required) ISO-3166 country code (e.g., US, GB, IN)."
                },
                {
                  "disabled": false,
                  "key": "year",
                  "value": "<integer>",
                  "description": "(Required) Year to retrieve holidays for. Historical data available through 2049."
                },
                {
                  "disabled": false,
                  "key": "day",
                  "value": "<integer>",
                  "description": "Filter to a specific day of the month (1-31)."
                },
                {
                  "disabled": false,
                  "key": "month",
                  "value": "<integer>",
                  "description": "Filter to a specific month (1-12)."
                },
                {
                  "disabled": false,
                  "key": "location",
                  "value": "<string>",
                  "description": "ISO-3166 state or region code (e.g., us-ca for California)."
                },
                {
                  "disabled": false,
                  "key": "type",
                  "value": "<string>",
                  "description": "Filter by holiday type (national, local, religious, observance)."
                },
                {
                  "disabled": false,
                  "key": "language",
                  "value": "<string>",
                  "description": "Premium parameter. Two-letter ISO639 language code."
                },
                {
                  "disabled": false,
                  "key": "uuid",
                  "value": "<boolean>",
                  "description": "Premium parameter. Include UUID values for each holiday."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
